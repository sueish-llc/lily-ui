{
  "name": "@lily-ui/vue",
  "version": "0.1.0",
  "description": "Lily UI — accessible (WCAG 2.1 AAA), SSR/SSG-ready Vue 3 component library. Markup + behavior + types; styling provided by @lily-ui/css.",
  "license": "MIT",
  "homepage": "https://github.com/sueish-llc/lily-ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sueish-llc/lily-ui.git",
    "directory": "packages/vue"
  },
  "bugs": "https://github.com/sueish-llc/lily-ui/issues",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "import": "./dist/tokens.js",
      "require": "./dist/tokens.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.build.json --emitDeclarationOnly",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "@lily-ui/css": "workspace:^",
    "vue": ">=3.5"
  },
  "devDependencies": {
    "@lily-ui/css": "workspace:*",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/vue": "^8.1.0",
    "@vitejs/plugin-vue": "^5.1.0",
    "jsdom": "^25.0.0",
    "temporal-polyfill": "^0.3.2",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.1.0"
  },
  "keywords": [
    "vue",
    "vue3",
    "component-library",
    "design-system",
    "ui",
    "accessibility",
    "wcag",
    "ssr",
    "typescript"
  ],
  "publishConfig": {
    "access": "public"
  }
}
