{
  "name": "@lily-ui/react",
  "version": "0.1.0",
  "description": "Lily UI — accessible (WCAG 2.1 AAA), SSR/SSG-ready React component library. Markup + behavior + types; styling provided by @lily-ui/css.",
  "license": "MIT",
  "homepage": "https://github.com/sueish-llc/lily-ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sueish-llc/lily-ui.git",
    "directory": "packages/react"
  },
  "bugs": "https://github.com/sueish-llc/lily-ui/issues",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "import": "./dist/tokens.js",
      "require": "./dist/tokens.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:a11y": "vitest run src/**/*.a11y.test.tsx",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@lily-ui/css": "workspace:^",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@lily-ui/css": "workspace:*",
    "@storybook/react": "^8.4.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^25.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "temporal-polyfill": "^0.3.2",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0",
    "vitest-axe": "^0.1.0"
  },
  "keywords": [
    "react",
    "component-library",
    "design-system",
    "ui",
    "accessibility",
    "wcag",
    "ssr",
    "typescript"
  ],
  "publishConfig": {
    "access": "public"
  }
}
