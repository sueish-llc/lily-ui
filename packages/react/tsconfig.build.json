{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "emitDeclarationOnly": true,
    "noEmit": false
  },
  "include": [
    "src"
  ],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.a11y.test.tsx",
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx",
    "src/test",
    "src/storybook"
  ]
}
