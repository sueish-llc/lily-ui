{
  "name": "@lily-ui/web-components",
  "version": "0.1.0",
  "description": "Lily UI — accessible (WCAG 2.1 AAA), framework-agnostic Web Components (custom elements). Light-DOM markup styled by @lily-ui/css; usable in any framework or none.",
  "license": "MIT",
  "homepage": "https://github.com/sueish-llc/lily-ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sueish-llc/lily-ui.git",
    "directory": "packages/web-components"
  },
  "bugs": "https://github.com/sueish-llc/lily-ui/issues",
  "type": "module",
  "sideEffects": [
    "./dist/define.js",
    "./dist/define.cjs",
    "./src/define.ts"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./define": {
      "types": "./dist/define.d.ts",
      "import": "./dist/define.js",
      "require": "./dist/define.cjs"
    },
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "import": "./dist/tokens.js",
      "require": "./dist/tokens.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@lily-ui/css": "workspace:^"
  },
  "devDependencies": {
    "@lily-ui/css": "workspace:*",
    "jsdom": "^25.0.0",
    "temporal-polyfill": "^0.3.2",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "web-components",
    "custom-elements",
    "component-library",
    "design-system",
    "ui",
    "accessibility",
    "wcag",
    "framework-agnostic",
    "typescript"
  ],
  "publishConfig": {
    "access": "public"
  }
}
