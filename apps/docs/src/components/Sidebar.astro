---
import SidebarNav from '../islands/SidebarNav.tsx';
import { buildNavGroups } from '../lib/nav';
import { useTranslations, type Locale } from '../i18n/ui';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const groups = buildNavGroups(locale);
---

<SidebarNav
  client:load
  groups={groups}
  labels={{
    nav: t('nav.components'),
    search: t('nav.search'),
    searchEmpty: t('nav.searchEmpty'),
  }}
/>
