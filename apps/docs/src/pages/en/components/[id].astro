---
import Base from '../../../layouts/Base.astro';
import ComponentDetail from '../../../components/ComponentDetail.astro';
import { components, getComponent, localizedSummary } from '../../../registry';
import { useTranslations } from '../../../i18n/ui';

export function getStaticPaths() {
  return components.map((c) => ({ params: { id: c.id } }));
}

const { id } = Astro.params;
const component = getComponent(id!);
if (!component) return Astro.redirect('/404');
const t = useTranslations('en');
const summary = localizedSummary(component, 'en');
---

<Base
  locale="en"
  title={component.displayName}
  description={summary.text || t('site.description')}
  pagePath={`components/${component.id}/`}
>
  <ComponentDetail locale="en" component={component} />
</Base>
